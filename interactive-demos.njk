---
layout: base.njk
title: Interactive Demos
permalink: /interactive-demos/
---

{# Card image mapping: project ID -> image filename #}
{% set cardImages = {
  'chatbot-demo': 'chatbot-demo-card.jpg',
  'style-editor': 'style-editor-card.jpg'
} %}

{# Company/client mapping for header display #}
{% set companyMap = {
  'chatbot-demo': 'GskiFlix',
  'style-editor': 'Sample'
} %}

{# Short title mapping for cleaner display #}
{% set titleMap = {
  'chatbot-demo': 'Support Chatbot',
  'style-editor': 'Style Guide Editor'
} %}

<section class="category-landing">
  <div class="category-landing__header">
    <h1>Interactive Demos</h1>
    <p class="category-landing__intro">Working tools that demonstrate content design and conversation design in action. These aren't mockups—they're live, functional applications powered by LLMs.</p>
  </div>

  <div class="landing-cards">
    {% for section in navigation.section %}
      {% if section['@_id'] === 'interactive-demos' %}
        {% if section.item.length %}
          {% for item in section.item %}
            {% set project = projects | findProject(item['@_id']) %}
            {% set company = companyMap[item['@_id']] or 'Project' %}
            {% set shortTitle = titleMap[item['@_id']] or item['@_label'] %}

            <a href="/projects/{{ item['@_id'] }}/" class="landing-card">
              <div class="landing-card__header">
                <span class="landing-card__company">{{ company }}</span>
                <span class="landing-card__divider">|</span>
                <h3 class="landing-card__title">{{ shortTitle }}</h3>
              </div>
              <div class="landing-card__body">
                <div class="landing-card__image">
                  {% if cardImages[item['@_id']] %}
                  <img src="/assets/images/{{ cardImages[item['@_id']] }}" alt="{{ item['@_label'] }}">
                  {% endif %}
                </div>
                <div class="landing-card__content">
                  <p class="landing-card__teaser">
                    {% if project and project.meta and project.meta.teaser %}
                      {{ project.meta.teaser }}
                    {% else %}
                      Interactive demo coming soon.
                    {% endif %}
                  </p>
                  {% if project and project.meta and project.meta.tags and project.meta.tags.tag %}
                  <div class="landing-card__tags">
                    {% for tag in project.meta.tags.tag %}
                    <span class="landing-card__tag">{{ tag }}</span>
                    {% endfor %}
                  </div>
                  {% endif %}
                </div>
              </div>
            </a>
          {% endfor %}
        {% else %}
          {# Handle single item case #}
          {% set item = section.item %}
          {% set project = projects | findProject(item['@_id']) %}
          {% set company = companyMap[item['@_id']] or 'Project' %}
          {% set shortTitle = titleMap[item['@_id']] or item['@_label'] %}

          <a href="/projects/{{ item['@_id'] }}/" class="landing-card">
            <div class="landing-card__header">
              <span class="landing-card__company">{{ company }}</span>
              <span class="landing-card__divider">|</span>
              <h3 class="landing-card__title">{{ shortTitle }}</h3>
            </div>
            <div class="landing-card__body">
              <div class="landing-card__image">
                {% if cardImages[item['@_id']] %}
                <img src="/assets/images/{{ cardImages[item['@_id']] }}" alt="{{ item['@_label'] }}">
                {% endif %}
              </div>
              <div class="landing-card__content">
                <p class="landing-card__teaser">
                  {% if project and project.meta and project.meta.teaser %}
                    {{ project.meta.teaser }}
                  {% else %}
                    Interactive demo coming soon.
                  {% endif %}
                </p>
                {% if project and project.meta and project.meta.tags and project.meta.tags.tag %}
                <div class="landing-card__tags">
                  {% for tag in project.meta.tags.tag %}
                  <span class="landing-card__tag">{{ tag }}</span>
                  {% endfor %}
                </div>
                {% endif %}
              </div>
            </div>
          </a>
        {% endif %}
      {% endif %}
    {% endfor %}
  </div>
</section>
